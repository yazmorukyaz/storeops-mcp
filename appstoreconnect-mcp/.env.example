# App Store Connect API key for metadata, screenshots, IAPs, subscriptions, pricing, builds, and review operations.
# Note: Sales & Trends/downloads reports require a key with Admin, Finance, or Sales access.
ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_PRIVATE_KEY_PATH=/absolute/path/AuthKey_XXXXXXXXXX.p8

# Optional default vendor number for Sales & Trends/downloads reports
# (shown under Payments and Financial Reports). Used when a tool call omits vendor_number.
ASC_VENDOR_NUMBER=

# Optional App Store Connect API base override.
ASC_API_BASE=https://api.appstoreconnect.apple.com/v1

# Optional Apple In-App Purchase key for App Store Server API / RevenueCat Apple integration workflows.
APPLE_IAP_KEY_ID=
APPLE_IAP_ISSUER_ID=
APPLE_IAP_PRIVATE_KEY_PATH=/absolute/path/SubscriptionKey_XXXXXXXXXX.p8

# Optional legacy subscription credential.
APPLE_SHARED_SECRET=
